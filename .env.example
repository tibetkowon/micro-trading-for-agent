# KIS (Korea Investment & Securities) API Credentials
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_TYPE=01   # 01=종합계좌, 22=선물옵션

# KIS API Base URLs
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_MOCK_URL=https://openapivts.koreainvestment.com:29443

# Use mock/paper trading environment (true=모의투자, false=실전투자)
KIS_IS_MOCK=true

# Database
DATABASE_PATH=./data/trading.db

# Server
SERVER_PORT=8080

# Frontend static files (React build output)
FRONTEND_DIST_PATH=./frontend/dist
