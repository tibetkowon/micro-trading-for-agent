# KIS (Korea Investment & Securities) API Credentials
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=        # 계좌번호 체계(8-2)의 앞 8자리만 입력 (예: 12345678)
KIS_ACCOUNT_TYPE=01   # 계좌번호 뒤 2자리 (01=종합계좌, 22=선물옵션)

# KIS HTS ID — 실시간 체결통보(H0STCNI0) 구독 시 필요. 미설정 시 체결통보 미구독.
KIS_HTS_ID=

# KIS API Base URLs
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
# 모의투자: KIS_BASE_URL=https://openapivts.koreainvestment.com:29443

# Database
DATABASE_PATH=./data/trading.db

# Server
SERVER_PORT=8080

# Frontend static files (React build output)
FRONTEND_DIST_PATH=./frontend/dist

# MQTT — 실시간 알림 브로커 (Mosquitto)
# 브로커 미설치 시 이 항목을 비워두면 서버는 정상 기동되며 알림은 로그로만 남음
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_CLIENT_ID=micro-trading-server

# Anthropic Claude API — 자율 종목 선정 및 일일 리포트 생성
# 미설정 시 서버는 정상 기동되지만 09:15 자동매매 엔진이 동작하지 않음
ANTHROPIC_API_KEY=
